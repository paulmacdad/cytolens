{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CytoLens",
  "version": "0.1.0",
  "identifier": "com.cytolens.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @cytolens/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @cytolens/web build",
    "frontendDist": "../../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CytoLens",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
